# Darna — variables d'environnement
# Copier ce fichier en `.env.local` (gitignored) puis remplir.
# Toutes les variables sont parsées au démarrage via `lib/env.ts` (Zod fail-fast).

# URL canonique publique de l'app (origin sans trailing slash).
# Dev : http://localhost:3000 — Preview/Prod : https://darna.org
# Source unique pour construire les redirectTo des magic-links (anti host-header injection).
NEXT_PUBLIC_SITE_URL=

# Supabase (nouvelles clés sb_*, deprecation des anon/service_role fin 2026)
# Format attendu : sb_publishable_* et sb_secret_*
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Brevo (transactional e-mail FR)
# Sender domain MUST have SPF + DKIM + DMARC configured (cf. docs/ops/brevo-sender-setup.md).
# Recommandé en prod : noreply@darna.org
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Darna
# Fallback e-mail transactionnel (optionnel) — utilisé en staging tant que le
# sender domain Brevo n'est pas validé (cf. lib/email/client.ts).
RESEND_API_KEY=

# GlitchTip Cloud EU (observabilité errors)
GLITCHTIP_DSN=
NEXT_PUBLIC_GLITCHTIP_DSN=

# Upstash Redis EU (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Cron
CRON_SECRET=

# Story 2.4 — consentement artisan
# Secret HMAC des tokens de consentement (magic-link SMS), ≥32 caractères aléatoires.
CONSENT_TOKEN_SECRET=
# Story 2.6 — secret HMAC du suffixe pseudonyme FR16 (≥32 chars, distinct du CONSENT_TOKEN_SECRET).
PSEUDONYM_SECRET=
# Provider SMS : `log` (défaut MVP, loggue le lien sans envoi), `brevo` ou `twilio`.
SMS_PROVIDER=log
# Sender alphanumérique (≤11 car) requis si SMS_PROVIDER=brevo.
BREVO_SMS_SENDER=
# Requis si SMS_PROVIDER=twilio : credentials console Twilio + un expéditeur
# (Messaging Service recommandé — porte le sender ID Maroc pré-enregistré —
# sinon TWILIO_FROM = numéro E.164 ou sender alphanumérique ≤11).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM=

# GlitchTip / Sentry (sourcemaps CI-only)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Opérations
LEGAL_CONTACT_EMAIL=
INITIAL_COMOD_EMAILS=

# Cloudflare R2 — backup hebdo (ADR 0007, scaffold : optionnels tant que le bucket
# n'est pas provisionné ; requis en prod pour l'Edge Function weekly-backup).
# NB : distincts de R2_API_TOKEN (token Cloudflare API du script budget-alert CI).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
